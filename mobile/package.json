{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:web-build": "expo export --platform web",
    "symbols:update": "node ./scripts/update-symbol-universe.mjs",
    "qa": "npm run typecheck && npm run test:unit && npm run test:web-build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/native": "^7.1.28",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "^55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "^55.0.8",
    "expo-image-picker": "^55.0.12",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-sharing": "^55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  },
  "private": true
}
